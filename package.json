{
  "name": "caesar-agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "GPL-3.0-only",
  "description": "CaesarAgent — author-once AI agent harness for expert coding agents and native cross-tool outputs.",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck && pnpm typecheck:scripts",
    "typecheck:scripts": "tsc -p scripts/tsconfig.json",
    "lint": "biome check .",
    "format": "biome format --write .",
    "validate": "node packages/cli/dist/index.js validate --strict",
    "assemble": "tsx scripts/assemble-category-packages.ts",
    "ci": "pnpm typecheck && pnpm build && pnpm test && pnpm validate && pnpm lint"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.4",
    "@caesar/agents-core": "workspace:*",
    "@types/node": "20.19.21",
    "tsup": "8.5.0",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
