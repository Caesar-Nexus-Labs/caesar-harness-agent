// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`kiloEmitter > snapshot 1`] = `
"customModes:
  - slug: feature-builder
    name: Feature Builder
    roleDefinition: You are an expert code reviewer.
    whenToUse: Implements features end-to-end across the codebase with full tooling.
    description: Implements features end-to-end across the codebase with full tooling.
    customInstructions: |-
      ## When to Use
      After code is written or modified.

      ## Workflow
      1. Read the diff. 2. Flag issues. 3. Report.

      ## Checklist & Heuristics
      - Correctness before style.

      ## Output Contract
      A prioritized list of findings.

      ## Boundaries
      Never modify code; review only.
    groups:
      - read
      - edit
      - command
  - slug: test-writer
    name: Test Writer
    roleDefinition: You are an expert code reviewer.
    whenToUse: Writes and maintains automated tests for new and changed code paths.
    description: Writes and maintains automated tests for new and changed code paths.
    customInstructions: |-
      ## When to Use
      After code is written or modified.

      ## Workflow
      1. Read the diff. 2. Flag issues. 3. Report.

      ## Checklist & Heuristics
      - Correctness before style.

      ## Output Contract
      A prioritized list of findings.

      ## Boundaries
      Never modify code; review only.
    groups:
      - read
      - edit
  - slug: security-auditor
    name: Security Auditor
    roleDefinition: You are an expert code reviewer.
    whenToUse: Read-only security auditor for vulnerability review and threat assessment.
    description: Read-only security auditor for vulnerability review and threat assessment.
    customInstructions: |-
      ## When to Use
      After code is written or modified.

      ## Workflow
      1. Read the diff. 2. Flag issues. 3. Report.

      ## Checklist & Heuristics
      - Correctness before style.

      ## Output Contract
      A prioritized list of findings.

      ## Boundaries
      Never modify code; review only.
    groups:
      - read
"
`;
